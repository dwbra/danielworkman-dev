---
import Layout from '../../layouts/Layout.astro';
import blogs from '../../data/blogs.json';

export const prerender = true;
export async function getStaticPaths() {
  return blogs.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<Layout title={`${post.title} | Daniel Workman`}>
	<section class="section-container py-24">
		<div class="max-w-3xl mx-auto">
			<a href="/blog" class="text-forest-600 hover:text-forest-800 transition-colors font-bold flex items-center gap-2 mb-12">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
				Back to blog
			</a>
			
			<div class="text-forest-500 font-mono text-sm font-bold uppercase tracking-[0.2em] mb-4">
				{post.date}
			</div>
			<h1 class="text-5xl md:text-7xl font-bold text-slate-900 mb-8 leading-[1.1]">{post.title}</h1>
			
			<div class="flex flex-wrap gap-2 mb-12">
				{post.tags.map(tag => (
					<span class="tag">{tag}</span>
				))}
			</div>

			<div class="rich-content border-t border-slate-100 pt-12">
				<p>{post.content}</p>
			</div>
		</div>
	</section>
</Layout>
