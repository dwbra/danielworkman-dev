---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Daniel Workman's professional portfolio and work profile." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body>
		<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
			<nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="text-xl font-bold tracking-tight text-slate-900 hover:text-forest-600 transition-colors">
					DW<span class="text-forest-500">.</span>
				</a>
				<ul class="flex gap-6 md:gap-8">
					<li><a href="/" class="nav-link text-sm font-medium">Home</a></li>
					<li><a href="/projects" class="nav-link text-sm font-medium">Projects</a></li>
					<li><a href="/blog" class="nav-link text-sm font-medium">Blog</a></li>
					<li><a href="/#about" class="nav-link text-sm font-medium">About</a></li>
				</ul>
			</nav>
		</header>

		<main class="pt-16">
			<slot />
		</main>

		<footer class="border-t border-slate-100 py-12 mt-20">
			<div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
				<p class="text-slate-500 text-sm">
					© {new Date().getFullYear()} Daniel Workman. Built with Astro & Cloudflare.
				</p>
				<div class="flex gap-6">
					<a href="https://github.com/dwbra" class="text-slate-500 hover:text-forest-600 transition-colors text-sm" target="_blank" rel="noopener noreferrer">GitHub</a>
					<a href="https://www.linkedin.com/in/danielworkman1/" class="text-slate-500 hover:text-forest-600 transition-colors text-sm" target="_blank" rel="noopener noreferrer">LinkedIn</a>
					<a href="/#contact" class="text-slate-500 hover:text-forest-600 transition-colors text-sm">Contact</a>
				</div>
			</div>
		</footer>
	</body>
</html>
